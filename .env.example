# YouTube Data API key — get one at https://console.cloud.google.com/
# Enable "YouTube Data API v3" for your project.
# Restrict the key to HTTP referrers (your domain + localhost) for security.
VITE_YOUTUBE_API_KEY=your_api_key_here

# YouTube playlist for Shorts — paste the full URL or just the playlist ID
# Example: https://www.youtube.com/playlist?list=PLxxxxxxxx
# IMPORTANT: Playlist must be Unlisted or Public (Private won't work with API key)
VITE_YOUTUBE_PLAYLIST_ID=

# Long format build video for the "Watch the Build Process" section
# Example: https://www.youtube.com/watch?v=7Ol9WkUZeus  or just 7Ol9WkUZeus
VITE_YOUTUBE_BUILD_VIDEO_ID=